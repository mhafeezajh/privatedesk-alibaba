# ============================================================================
# PrivateDesk MemoryAgent — environment
# Copy to .env and fill in. The ONLY change between cloud and local is this block.
# ============================================================================

# ---- DEPLOYMENT PATH SELECTOR -------------------------------------------------
# If DASHSCOPE_API_KEY is set, all LLM/embedding calls route to Qwen Cloud.
# If it is empty, the stack falls back to the local Ollama config below.
DASHSCOPE_API_KEY=

# ---- CLOUD PATH (Qwen Cloud / DashScope, Singapore intl endpoint) ------------
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_REASONING_MODEL=dashscope/qwen-plus
LLM_HEADLINE_MODEL=dashscope/qwen3-max
EMBEDDING_MODEL=dashscope/text-embedding-v4
EMBEDDING_DIM=1024

# ---- LOCAL PATH (Ollama, used automatically when DASHSCOPE_API_KEY is empty) -
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_LLM_REASONING_MODEL=ollama/qwen3:8b
LOCAL_LLM_HEADLINE_MODEL=ollama/qwen3:32b
LOCAL_EMBEDDING_MODEL=ollama/nomic-embed-text
LOCAL_EMBEDDING_DIM=768

# ---- INFRA (compose wires these; defaults work out of the box) ---------------
POSTGRES_DSN=postgresql+asyncpg://privatedesk:privatedesk@postgres:5432/privatedesk
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379/0

# ---- MEMORY ENGINE TUNABLES --------------------------------------------------
K_CANDIDATES=20          # vectors pulled from Qdrant before rerank
K_CONTEXT=6              # memories actually injected into the prompt (bounded recall)
DEDUP_THRESHOLD=0.92     # cosine above which two memories are near-duplicates
SALIENCE_PRUNE_FLOOR=0.2 # below this + long unused -> demoted out of active recall
RERANK_W_SIM=0.6         # weight: cosine similarity
RERANK_W_SAL=0.25        # weight: salience
RERANK_W_REC=0.15        # weight: recency
ISOLATION_MODE=collection_per_member  # "collection_per_member" | "single_collection"

# ---- APP ---------------------------------------------------------------------
SESSION_SECRET=change-me-in-prod
APP_ENV=dev
