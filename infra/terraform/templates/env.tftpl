# Rendered by Terraform — do not edit on the server; change tfvars and re-apply.
# Cloud vs local is decided by DASHSCOPE_API_KEY presence (see api/app/config.py).

DASHSCOPE_API_KEY=${dashscope_api_key}

# ---- CLOUD PATH (Qwen Cloud / DashScope, Singapore intl endpoint) ----
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_REASONING_MODEL=dashscope/qwen-plus
LLM_HEADLINE_MODEL=dashscope/qwen3-max
EMBEDDING_MODEL=dashscope/text-embedding-v4
EMBEDDING_DIM=1024

# ---- LOCAL PATH (Ollama; used only if DASHSCOPE_API_KEY is empty) ----
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_LLM_REASONING_MODEL=ollama/qwen3:8b
LOCAL_LLM_HEADLINE_MODEL=ollama/qwen3:32b
LOCAL_EMBEDDING_MODEL=ollama/nomic-embed-text
LOCAL_EMBEDDING_DIM=768

# ---- INFRA (compose network; do not point these at public ports) ----
POSTGRES_DSN=postgresql+asyncpg://privatedesk:privatedesk@postgres:5432/privatedesk
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379/0

# ---- MEMORY ENGINE TUNABLES ----
# K_CANDIDATES is the vector-search candidate pool the reranker sees. On matters
# with 100+ memories, 20 is too small — high-salience "needle" facts can sit
# below cosine-rank 20 and never reach the salience-weighted rerank. 64 gives the
# reranker enough of the corpus to surface them while K_CONTEXT still bounds the
# prompt to the top few.
K_CANDIDATES=${k_candidates}
K_CONTEXT=6
DEDUP_THRESHOLD=0.92
SALIENCE_PRUNE_FLOOR=0.2
RERANK_W_SIM=0.6
RERANK_W_SAL=0.25
RERANK_W_REC=0.15
ISOLATION_MODE=collection_per_member

# ---- APP ----
SESSION_SECRET=${session_secret}
APP_ENV=prod
