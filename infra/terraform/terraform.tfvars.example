# Copy to terraform.tfvars and adjust. Secrets are better passed as env vars
# (TF_VAR_dashscope_api_key=…) than written here, but either works.

region        = "ap-southeast-1"   # Singapore, near the DashScope intl endpoint
project       = "privatedesk"
instance_type = "ecs.u1-c1m4.large"   # 2 vCPU / 8 GB (cheap + builds reliably; u1-c1m4.xlarge = 4c/16g)

# Lock SSH to your own IP for anything longer-lived than a demo:
# admin_cidr = "203.0.113.4/32"
admin_cidr = "0.0.0.0/0"
app_cidr   = "0.0.0.0/0"           # who can reach ports 3000 / 8000

seed_demo = true

# Prefer:  export TF_VAR_dashscope_api_key=sk-...
# dashscope_api_key = "sk-..."
# session_secret   = ""            # empty => auto-generated
